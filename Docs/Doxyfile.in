#---------------------------------------------------------------------------
# zcore Doxygen Configuration
#---------------------------------------------------------------------------

DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = "zcore"
PROJECT_NUMBER         = "dev"
PROJECT_BRIEF          = "Foundational C++ primitives for Zynos Software"
OUTPUT_DIRECTORY       = @CMAKE_BINARY_DIR@/docs/doxygen
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = NO
INLINE_INHERITED_MEMB  = NO
FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = @CMAKE_SOURCE_DIR@

JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = YES
MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 3
AUTOLINK_SUPPORT       = YES

BUILTIN_STL_SUPPORT    = YES
CPP_CLI_SUPPORT        = NO
SIP_SUPPORT            = NO
IDL_PROPERTY_SUPPORT   = YES
DISTRIBUTE_GROUP_DOC   = NO

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_LOCAL_METHODS  = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES
HIDE_FRIEND_COMPOUNDS  = NO
HIDE_IN_BODY_DOCS      = NO

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_IF_UNDOC_ENUM_VAL = YES
WARN_AS_ERROR          = NO
WARN_LOGFILE           = @CMAKE_BINARY_DIR@/docs/doxygen/doxygen-warnings.log

INPUT                  = @CMAKE_SOURCE_DIR@/include \
                         @CMAKE_SOURCE_DIR@/README.md
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.hpp \
                         *.md
RECURSIVE              = YES
EXCLUDE_SYMLINKS       = NO
EXCLUDE_PATTERNS       = */tests/* \
                         */include/zcore/hash/detail/* \
                         */cmake-build-*/*
EXCLUDE_SYMBOLS        = zcore::detail* \
                         zcore::hash::detail* \
                         std::hash< zcore::Id< TagT, ValueT, InvalidV > >

USE_MDFILE_AS_MAINPAGE = @CMAKE_SOURCE_DIR@/README.md

INCLUDE_PATH           = @CMAKE_SOURCE_DIR@/include \
                         @CMAKE_SOURCE_DIR@/thirdparty/xxhash
INCLUDE_FILE_PATTERNS  = *.h \
                         *.hpp
PREDEFINED             =
EXPAND_AS_DEFINED      =
SKIP_FUNCTION_MACROS   = YES

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
SEARCH_INCLUDES        = YES

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE        = @ZCORE_DOXYGEN_HTML_COLORSTYLE@
HTML_DYNAMIC_MENUS     = YES
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = @ZCORE_DOXYGEN_FULL_SIDEBAR@
DISABLE_INDEX          = NO
HTML_EXTRA_STYLESHEET  = @ZCORE_DOXYGEN_AWESOME_CSS@

GENERATE_XML           = NO
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_DOCBOOK       = NO
